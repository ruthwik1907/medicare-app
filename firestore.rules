rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function hasRole(role) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role == role;
    }
    
    function isStaff() {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role in ['admin', 'doctor', 'receptionist', 'pharmacist', 'lab_technician'];
    }
    
    function isAdmin() {
      let userData = getUserData();
      return isAuthenticated() && 
        ((userData != null && userData.role == 'admin') || 
         (request.auth.token.email == "220701237@rajalakshmi.edu.in" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "admin@hospital.com"));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // Anyone can read users (needed for doctors list, patient search, etc)
      allow read: if true;
      
      // Users can create their own profile, but only as a patient unless they are an admin
      allow create: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == 'patient') || 
        isAdmin()
      );
      
      // Users can update their own profile, but cannot change their role
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /doctorSchedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasRole('doctor') || hasRole('receptionist');
    }

    match /appointments/{appointmentId} {
      // Patients can read their own, staff can read all
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      
      // Patients can create for themselves, staff can create for anyone
      allow create: if isAuthenticated() && (isStaff() || request.resource.data.patientId == request.auth.uid);
      
      // Patients can update their own (e.g. cancel), staff can update all
      allow update: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      
      allow delete: if isAdmin();
    }

    match /medicalRecords/{recordId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      allow write: if hasRole('doctor') || isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      allow create: if hasRole('doctor') || isAdmin();
      allow update: if hasRole('doctor') || hasRole('pharmacist') || isAdmin();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      allow write: if hasRole('receptionist') || isAdmin();
    }

    match /labRequests/{requestId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      allow write: if hasRole('doctor') || hasRole('lab_technician') || isAdmin();
    }

    match /labReports/{reportId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      allow write: if hasRole('lab_technician') || hasRole('doctor') || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
